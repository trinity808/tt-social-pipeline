# Copy this file to .env and fill in real values. Never commit .env itself.

# --- GCP ---
GCP_PROJECT_ID=
GCP_REGION=
GOOGLE_APPLICATION_CREDENTIALS=  # local path to service account JSON, e.g. ./credentials/sa-key.json

# --- LLM providers ---
GROQ_API_KEY=
VERTEX_AI_LOCATION=              # only needed if using Gemini via Vertex AI

# --- Content source ---
TT_SITE_URL=                     # page(s) to fetch content from

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN= 
LINKEDIN_ORG_URN=

# --- Meta (Facebook + Instagram) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Image generation (Sukanya's DALL-E 3 step) ---
OPENAI_API_KEY=

# --- Human review gate (fill in whichever channel you decide on) ---
REVIEW_SLACK_WEBHOOK_URL=
REVIEW_EMAIL_ADDRESS=

# --- Optional: agent tracing ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tt-social-pipeline
